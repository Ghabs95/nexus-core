# Nexus Configuration environment variables
# Copy this to .env and populate with your keys.

# ================================
# BOT TOKENS & IDENTITY
# ================================
# Telegram Bot Token (from BotFather)
TELEGRAM_TOKEN=your_telegram_token_here

# Authorized Telegram User IDs (comma-separated list of numeric IDs)
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Confirmation mode: always | smart | never
TASK_CONFIRMATION_MODE=smart

# ================================
# PROJECT & PATHS
# ================================
# Workspace base directory (where your git repos live)
BASE_DIR=/home/ubuntu/git

# Path to the project_config.yaml
PROJECT_CONFIG_PATH=config/project_config.yaml

# Runtime storage (recommended: an absolute path outside the repo)
NEXUS_RUNTIME_DIR=/var/lib/nexus
LOGS_DIR=/var/lib/nexus/logs

# ================================
# GIT PLATFORMS
# ================================
# Allow service-level git token fallback when no per-user OAuth token is available.
# Set to false to enforce user-token-only git API auth.
NEXUS_ALLOW_SERVICE_GIT_TOKEN_FALLBACK=true

# Git platform transport: api | cli
# api uses direct GitHub/GitLab REST API adapters (default, recommended).
# cli uses gh/glab-backed adapters.
NEXUS_GIT_PLATFORM_TRANSPORT=api

# GitHub Personal Access Token
GITHUB_TOKEN=your_github_token_here

# GitLab Personal Access Token (Optional)
# GITLAB_TOKEN=glpat-your_gitlab_token_here
# GITLAB_BASE_URL=https://gitlab.com

# Webhook configuration (for GitHub/GitLab events)
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_PORT=8081
# Internal URL used by bot/processor containers to reach the webhook service.
# Compose deployments should usually leave this at the service DNS name.
NEXUS_WEBHOOK_INTERNAL_URL=http://webhook:8081

# ================================
# INFRASTRUCTURE / STORAGE
# ================================
# Deployment mode: compose | systemd
DEPLOY_TYPE=compose
OBSERVABILITY_ENABLED=false
INFRA_ENABLED=false

# Set to 'postgres' to enable enterprise database-backed mode
NEXUS_STORAGE_BACKEND=postgres

# Storage DSN used when a postgres backend is selected
NEXUS_STORAGE_DSN=postgresql://nexus:nexus@127.0.0.1:5432/nexus

# Optional domain overrides (leave unset to inherit NEXUS_STORAGE_BACKEND)
# NEXUS_WORKFLOW_BACKEND=postgres
# NEXUS_INBOX_BACKEND=postgres
# NEXUS_HOST_STATE_BACKEND=postgres

# Redis URL for conversational memory and multi-platform state
REDIS_URL=redis://localhost:6379/0

# Observability (Grafana login)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_now

# Skip completions older than this window at startup (seconds)
NEXUS_COMPLETION_REPLAY_WINDOW_SECONDS=1800

# ================================
# AI / PERSONA SETTINGS
# ================================
# Base AI system prompt/persona for chat interactions
AI_PERSONA=You are Nexus, an elite technical and business execution advisor. Prioritize clarity, speed, and leverage. Give direct recommendations, surface tradeoffs and risks, and propose concrete next actions with an operator mindset. Stay professional, concise, and highly practical.

# AI analysis timeout (seconds)
AI_ANALYSIS_TIMEOUT=300

# Max retries before provider is marked unavailable
AI_MAX_RETRIES=3

# Voice transcription provider: whisper | gemini | copilot
TRANSCRIPTION_PRIMARY=whisper
WHISPER_MODEL=small
WHISPER_LANGUAGES=en,it

# ================================
# OTHER INTEGRATIONS (OPTIONAL)
# ================================
# Discord Bot Token
DISCORD_TOKEN=your_discord_token_here
DISCORD_ALLOWED_USER_IDS=123456789

# ================================
# AUTH / BYOK (DISCORD + TELEGRAM MVP)
# ================================
# Enable OAuth onboarding and per-user credentials (GitHub/GitLab + Codex/Gemini/Claude/Copilot)
NEXUS_AUTH_ENABLED=true
NEXUS_PUBLIC_BASE_URL=https://nexus.example.com
NEXUS_GITHUB_CLIENT_ID=your_github_oauth_client_id
NEXUS_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
NEXUS_AUTH_ALLOWED_GITHUB_ORGS=Ghabs95
NEXUS_GITLAB_BASE_URL=https://gitlab.com
NEXUS_GITLAB_CLIENT_ID=your_gitlab_oauth_app_id
NEXUS_GITLAB_CLIENT_SECRET=your_gitlab_oauth_app_secret
NEXUS_AUTH_ALLOWED_GITLAB_GROUPS=ghabs/nexus-team,ghabs/acme-team
NEXUS_CREDENTIALS_MASTER_KEY=base64_encoded_32_byte_key
NEXUS_CREDENTIALS_KEY_VERSION=1
NEXUS_AUTH_SESSION_TTL_SECONDS=900
NEXUS_ACCESS_SYNC_INTERVAL_MINUTES=30
# Optional strict Codex key live validation via OpenAI API:
# NEXUS_AUTH_VALIDATE_CODEX_KEY=true
# Optional strict Gemini key live validation:
# NEXUS_AUTH_VALIDATE_GEMINI_KEY=true
# Optional strict Claude key live validation:
# NEXUS_AUTH_VALIDATE_CLAUDE_KEY=true

# ================================
# VISUALIZER ACCESS GUARD
# ================================
# Set false to hard-disable /visualizer, /visualizer/snapshot, and visualizer sockets.
NEXUS_VISUALIZER_ENABLED=true

# Shared token for visualizer access (useful in filesystem mode when NEXUS_AUTH_ENABLED=false).
# Users can paste it in the visualizer access page at "/" or send it as:
# - Header: X-Nexus-Visualizer-Token: <token>
# - Header: Authorization: Bearer <token>
NEXUS_VISUALIZER_SHARED_TOKEN=replace_with_a_long_random_secret
# Optional dedicated token for the internal Telegram watch client.
# Leave unset to reuse NEXUS_VISUALIZER_SHARED_TOKEN.
# NEXUS_TELEGRAM_WATCH_SHARED_TOKEN=replace_with_a_long_random_secret

# Slack Bot configuration
# SLACK_TOKEN=xoxb-your_bot_token_here
# SLACK_APP_TOKEN=xapp-your_app_token_here
# SLACK_SIGNING_SECRET=your_signing_secret_here
# SLACK_ALLOWED_USER_IDS=U123456789
